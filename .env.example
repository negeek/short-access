# Copy this file to .env and adjust the values.
# .env is git-ignored so your real secrets never get committed.

# Postgres connection.
POSTGRES_USER=sauser
POSTGRES_PASSWORD=sapass
POSTGRES_DB=sadb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Public base URL of this instance. Used to build the full short link
# that gets handed back to callers, e.g. https://sho.rt/abc123.
BASE_URL=http://localhost:8080

# Secret used to sign auth tokens. Set this to a long random string.
AUTH_KEY=change-me-to-a-long-random-secret

# Log verbosity: debug, info, warn or error. Defaults to info.
LOG_LEVEL=info
